# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/nepfluence_dev

# ============================================
# API & CORS
# ============================================
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development

# ============================================
# JWT & SECURITY
# ============================================
SECRET_KEY=your-super-secret-key-min-32-chars-change-in-production!!!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# EMAIL (Mailtrap / SendGrid / Gmail)
# ============================================
MAIL_SERVER=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password
MAIL_FROM=noreply@nepfluence.com
MAIL_USE_TLS=true

# ============================================
# GOOGLE OAUTH
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# YOUTUBE
# ============================================
YOUTUBE_API_KEY=your-youtube-api-key

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO